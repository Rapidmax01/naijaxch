{
  "name": "naijaxch",
  "version": "0.1.0",
  "private": true,
  "description": "Fluid NGX trend analysis — research, tools, and community for Nigerian stocks. Phase 1.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:up": "docker compose up -d db",
    "db:migrate": "prisma migrate dev",
    "db:timescale": "prisma db execute --file ./prisma/sql/timescale.sql --schema ./prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "ingest": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local src/ingestion/run.ts",
    "ai:generate": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.local src/ai/generate.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "decimal.js": "^10.4.3",
    "next": "^14.2.5",
    "next-auth": "^5.0.0-beta.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
