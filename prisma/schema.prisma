// NaijaXch — source-of-truth schema (Step 1: market data only).
// Postgres + TimescaleDB. The raw_prices table is converted to a TimescaleDB
// hypertable by a raw-SQL migration (see prisma/sql/timescale.sql) — Prisma
// models it as an ordinary table.
//
// GUARDRAIL: schema changes / migrations require human approval (CLAUDE.md #2).
// Money/quantities are NUMERIC (never float) to match the decimal.js rule.
// Auth/billing models are intentionally NOT here yet — they are a later, gated
// step (see docs/proposals/0001-persistence-auth-billing.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  ticker            String            @id
  name              String
  sector            String
  sharesOutstanding Decimal?          @map("shares_outstanding") @db.Decimal(20, 0)
  rawPrices         RawPrice[]
  corporateActions  CorporateAction[]
  fundamentals      Fundamentals[]

  @@map("companies")
}

model RawPrice {
  ticker  String
  date    DateTime @db.Date
  close   Decimal  @db.Decimal(18, 4) // unadjusted close (audit) — never plotted
  volume  BigInt
  company Company  @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  // PK includes `date` so it satisfies TimescaleDB's hypertable constraint.
  @@id([ticker, date])
  @@map("raw_prices")
}

model CorporateAction {
  id      String   @id @default(uuid())
  ticker  String
  exDate  DateTime @map("ex_date") @db.Date
  type    String // 'bonus' | 'split' | 'rights'
  terms   Json // BonusOrSplitTerms | RightsTerms
  company Company  @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@index([ticker, exDate])
  @@map("corporate_actions")
}

model Fundamentals {
  ticker           String
  period           String
  revenue          Decimal @db.Decimal(20, 2)
  netIncome        Decimal @map("net_income") @db.Decimal(20, 2)
  shareCount       Decimal @map("share_count") @db.Decimal(20, 0)
  dividendPerShare Decimal @map("dividend_per_share") @db.Decimal(18, 4)
  totalEquity      Decimal @map("total_equity") @db.Decimal(20, 2)
  totalDebt        Decimal @map("total_debt") @db.Decimal(20, 2)
  company          Company @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@id([ticker, period])
  @@map("fundamentals")
}

// --- Accounts (Step 3 — auth). Regulated PII (G4): never log rows. ---

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  emailVerified DateTime?            @map("email_verified")
  name          String?
  image         String?
  passwordHash  String?              @map("password_hash") // null for OAuth-only users
  tier          String               @default("free") // 'free' | 'premium' — billing (Step 5) flips this
  createdAt     DateTime             @default(now()) @map("created_at")
  accounts      Account[]
  sessions      Session[]
  watchlist     WatchlistItem[]
  holdings      Holding[]
  passwordResets PasswordResetToken[]

  @@map("users")
}

// Manual portfolio tracker — one holdings set per user (spec §7). Quantities are
// NUMERIC (never float). Summed × adjClose into the portfolio trend (spec §5.5).
model Holding {
  userId    String   @map("user_id")
  ticker    String
  quantity  Decimal  @db.Decimal(20, 4)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, ticker])
  @@map("holdings")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @map("refresh_token")
  access_token      String? @map("access_token")
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type")
  scope             String?
  id_token          String? @map("id_token")
  session_state     String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash") // store a hash of the token, never the token
  expires   DateTime
  usedAt    DateTime? @map("used_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model WatchlistItem {
  userId  String   @map("user_id")
  ticker  String
  addedAt DateTime @default(now()) @map("added_at")
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, ticker])
  @@map("watchlist_items")
}
