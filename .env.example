# NaijaXch — environment template (copy to .env.local; never commit real values — G5)

# --- Source-of-truth database (Postgres + TimescaleDB) ---
# Holds raw + adjusted prices, fundamentals, corporate actions, reference data.
DATABASE_URL="postgresql://user:password@localhost:5432/naijaxch?schema=public"

# --- App ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- NGX market data (licensed, delayed/EOD — G3) ---
# Distribution licence required. Phase 1: delayed/EOD tier only. Leave blank until licensed.
NGX_DATA_API_BASE=""
NGX_DATA_API_KEY=""

# --- AI summary service (narration only — numbers never come from the model, G1) ---
# Default to the latest Claude model when wired up.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"

# --- Auth (Auth.js / NextAuth v5; JWT sessions) ---
AUTH_SECRET=""            # generate: openssl rand -base64 32
AUTH_URL="http://localhost:3000"
# Google OAuth (optional — Google sign-in only appears when both are set)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Transactional email (Brevo) ---
BREVO_API_KEY=""
EMAIL_FROM="no-reply@naijaxch.com"

# --- Billing (Paystack) ---
# Provider holds funds; we only mirror status. Premium gating activates when both are set.
PAYSTACK_SECRET_KEY=""
PAYSTACK_PLAN_CODE=""        # the naira monthly plan created in the Paystack dashboard (price set there)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# Webhook: point Paystack at {APP_URL}/api/billing/webhook
